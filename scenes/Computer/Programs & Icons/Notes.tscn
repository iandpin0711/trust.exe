theme_override_colors/font_color = Color(0, 0, 0, 1)
text = "1. Open Contacts to identify a high-value target for your next operation.
					2. Cross-reference their activity by checking the Calls logs for patterns.
					3. Execute the hack or scam once you have gathered enough leverage."

